# FinatriX backend (Supabase) — copy this file to ".env" and fill in your values.
# Find both values in your Supabase project: Settings → API.
#
# These are PUBLIC client keys (safe to ship in a browser app). Never put the
# Supabase "service_role" key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY
